{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "src/**/*",
        "vite.config.ts",
        "config/**/*",
        "tests/**/*",
        "scripts/**/*"
    ],
    "exclude": ["node_modules", "dist", "build", "coverage", ".vite"]
}
