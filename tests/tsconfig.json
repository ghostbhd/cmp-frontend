{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "jsx": "react",
        "baseUrl": "..",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["vitest/globals", "@testing-library/jest-dom"],
        "allowImportingTsExtensions": false,
        "noEmit": true
    },
    "include": ["./**/*", "../src/**/*"],
    "exclude": ["../node_modules", "../dist"]
}
